{
  "name": "term-server",
  "version": "0.3.2",
  "description": "A fast, secure, Rust-powered web terminal workspace.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Agusx1211/term-server.git"
  },
  "homepage": "https://github.com/Agusx1211/term-server#readme",
  "bugs": "https://github.com/Agusx1211/term-server/issues",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "dev": "concurrently -k -n server,client -c blue,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "TERM_SERVER_PASSWORD=development cargo run -- --no-https --no-client --port 8090",
    "dev:client": "vite",
    "build": "npm run clean && npm run build:server && npm run build:client",
    "build:server": "cargo build --release",
    "build:client": "vite build",
    "package": "bash scripts/package-release.sh",
    "start": "target/release/term-server",
    "typecheck": "tsc -p tsconfig.client.json --noEmit",
    "test": "cargo test && vitest run",
    "test:web": "vitest run",
    "test:watch": "vitest",
    "check": "cargo fmt --check && cargo clippy --all-targets -- -D warnings && npm run typecheck && npm test && npm run build:client"
  },
  "dependencies": {
    "@codemirror/language": "^6.12.4",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/state": "^6.7.1",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "codemirror": "^6.0.2",
    "lucide-preact": "^1.25.0",
    "preact": "^10.29.7"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.6",
    "concurrently": "9.2.4",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
