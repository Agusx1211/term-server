# A password is generated on first boot when this is omitted.
TERM_SERVER_PASSWORD=replace-with-a-long-random-password
TERM_SERVER_HOST=127.0.0.1
TERM_SERVER_PORT=8090
TERM_SERVER_DATA_DIR=/var/lib/term-server
# TERM_SERVER_NO_HTTPS=true
# TERM_SERVER_SECURE_COOKIE=true
# TERM_SERVER_ALLOWED_ORIGINS=https://terminal.example.com
